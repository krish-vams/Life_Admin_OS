{
  "name": "life-admin-os",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack personal productivity and life admin platform.",
  "scripts": {
    "dev:backend": "npm --prefix backend run dev",
    "worker": "npm --prefix backend run worker",
    "dev:frontend": "npm --prefix frontend run dev",
    "start:backend": "npm --prefix backend start",
    "build:frontend": "npm --prefix frontend run build",
    "build": "npm --prefix frontend run build",
    "start:worker": "npm --prefix backend run worker",
    "deploy:check": "npm test && npm run build:frontend",
    "test": "npm --prefix backend test && npm --prefix frontend test"
  },
  "engines": {
    "node": ">=20"
  }
}
